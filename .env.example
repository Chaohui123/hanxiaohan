# ====================== ONZO 环境变量模板 ======================
# 复制此文件为 .env 并填入真实值
# 生产环境务必替换所有 CHANGE_ME 占位符

# ====================== 加密密钥（生产环境必填）======================
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SALT=CHANGE_ME_64_CHAR_RANDOM_HEX

# ====================== GLM 智谱视觉模型 ======================
GLM_API_KEY=CHANGE_ME_GLM_API_KEY
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_VISION_MODEL=glm-4.6v-flash

# ====================== DeepSeek 文本大模型 ======================
DEEPSEEK_API_KEY=CHANGE_ME_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro

# ====================== Ozon 店铺API密钥配置 ======================
OZON_API_KEYS=CHANGE_ME_OZON_API_KEYS
OZON_CLIENT_IDS=CHANGE_ME_OZON_CLIENT_IDS
OZON_API_BASE=https://api-seller.ozon.ru

# ====================== n8n 工作流引擎 ======================
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_N8N_PASSWORD
N8N_ENCRYPTION_KEY=CHANGE_ME_N8N_ENCRYPTION_KEY

# ====================== 应用服务基础配置 ======================
NODE_ENV=development
ENV=production
PORT=3000
LOG_LEVEL=info

# API 认证密钥（不设置则不启用鉴权，生产环境务必设置）
API_KEY=CHANGE_ME_API_KEY_32_CHARS
API_SERVICE_PORT=3000

# PostgreSQL 连接串
DATABASE_URL=postgresql://onzo:password@localhost:5432/onzo_prod
# SQLite 本地数据库文件路径（PG迁移前可用）
# SQLITE_DB_PATH=./data/onzo.db

# 模型并发令牌桶上限
MAX_AI_CONCURRENCY=10
MAX_TASK_CONCURRENCY=5

# LLM 单日 Token 上限（0=不限制）
LLM_DAILY_TOKEN_LIMIT=500000

# ====================== 通知渠道（可选）======================
NOTIFY_WECHAT_WEBHOOK=
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=

# ====================== Playwright 爬虫配置 ======================
SCRAPER_MAX_BROWSER_POOL=3
SCRAPER_REQUEST_DELAY_MIN=3000
SCRAPER_REQUEST_DELAY_MAX=5000
# 代理IP池（逗号分隔，格式: http://user:pass@ip:port 或 ip:port）
# SCRAPER_PROXY_LIST=http://user:pass@1.2.3.4:8080,http://user:pass@5.6.7.8:8080
# 从API拉取代理（如快代理/芝麻代理）
# SCRAPER_PROXY_API_URL=CHANGE_ME_PROXY_API_URL
# 验证码冷却时间（秒，默认300）
# SCRAPER_CAPTCHA_COOLDOWN_SEC=300

# ====================== 开发模式配置 ======================
# ENV=dev + ENABLE_MOCK=true 才会返回假数据
# 生产环境确保 ENV=production 且不设 ENABLE_MOCK
# ENABLE_MOCK=true

# ====================== 订单同步 ======================
ORDER_SYNC_PAGE_SIZE=50
ORDER_SYNC_INTERVAL_MINUTES=30
OZON_WEBHOOK_SECRET=CHANGE_ME

# ====================== 监控告警 ======================
# Prometheus 指标（生产环境启用）
PROMETHEUS_ENABLED=true
# OpenTelemetry 分布式追踪（需要 Jaeger/Tempo）
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# Grafana 管理密码
# GRAFANA_PASSWORD=CHANGE_ME

# ====================== 货代中转仓收货地址 ======================
# 1688供应商发货→货代代收→跨境巴士打包发往俄罗斯
FREIGHT_ADDRESS=广东省东莞市常平镇土塘港建路45号7号楼放兔喜240247室 韩小寒 18928225650

# ====================== 物流配送模块 ======================
# 总开关: true=启用货代自动下单+轨迹同步, false=仅保留原有手动回填
LOGISTICS_ENABLE=false
# 人工过渡物流模式: kuajingbus=启用跨境巴士半自动化导出/导入工作流
# 设置为kuajingbus后启用/api/order/export(导出待预报订单)、/api/logistics/import(导入运单号回填)
# /api/logistics/billing(导入物流费用账单)、/api/logistics/dashboard(运营看板)、定时TG告警
# 切换为标准API货代时改为留空，无需重构上层逻辑
# TRANSITION_LOGISTICS=kuajingbus
# 物流商选择: cdek | russian_post | boxberry | auto（默认，自动选最优）
LOGISTICS_PROVIDER=auto
# 多货代分流权重（逗号分隔，与 LOGISTICS_PROVIDER 顺序对应）
# 例如 CDEK 70%, Boxberry 30%: LOGISTICS_WEIGHTS=70,30
# LOGISTICS_WEIGHTS=70,30
# CDEK API 凭证（俄罗斯快递配送）
# CDEK_CLIENT_ID=CHANGE_ME
# CDEK_CLIENT_SECRET=CHANGE_ME
# CDEK_API_BASE=https://api.cdek.ru/v2
# CDEK发货城市代码（默认44=莫斯科）
# CDEK_SENDER_CITY_CODE=44
# 俄罗斯邮政 API（经济小件配送）
# RUSSIAN_POST_API_KEY=CHANGE_ME
# RUSSIAN_POST_TOKEN=CHANGE_ME
# Boxberry API 凭证（俄罗斯配送）
# BOXBERRY_API_TOKEN=CHANGE_ME
# BOXBERRY_API_BASE=https://api.boxberry.ru

# ====================== 数据库密码（Docker 部署时使用）======================
# POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
# REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ====================== 1688 开放平台（采购自动支付）======================
# AppKey: 从1688开放平台获取
ALIBABA_APP_KEY=CHANGE_ME_ALIBABA_APP_KEY
# 从1688开放平台后台复制 AppSecret
ALIBABA_APP_SECRET=CHANGE_ME_ALIBABA_APP_SECRET
# OAuth2.0 access token（有效期180天，过期需重新获取）
ALIBABA_ACCESS_TOKEN=CHANGE_ME_ALIBABA_ACCESS_TOKEN
ALIBABA_GATEWAY=https://gw.open.1688.com/openapi/
# 免密代扣买家ID
ALIBABA_DEDUCT_BUYER_ID=CHANGE_ME_DEDUCT_BUYER_ID
# 1688 采购风控：每分钟最大下单数（防高频触发风控）
PURCHASE_MAX_RPM=5
# 1688 采购风控：单日采购总额上限（元）
PURCHASE_DAILY_LIMIT_CY=5000
# 1688 采购风控：单笔最大金额（元）
PURCHASE_MAX_ORDER_CY=2000
# 1688消息回调IP白名单（默认阿里云杭州+俄罗斯节点）
# ALIBABA_CALLBACK_IPS=110.75.0.0/16,47.96.0.0/12
# 诚E赊备用渠道
# CHENGYISHE_BUYER_ID=
# 跨境宝备用渠道
# KUAJINGBAO_BUYER_ID=

# ====================== 腾讯云 COS 对象存储（图片上传）======================
# COS_SECRET_ID=CHANGE_ME_COS_SECRET_ID
# COS_SECRET_KEY=CHANGE_ME_COS_SECRET_KEY
# COS_BUCKET=CHANGE_ME_COS_BUCKET
# COS_REGION=ap-shanghai
# COS_BASE_URL=https://CHANGE_ME_COS_BUCKET.cos.ap-shanghai.myqcloud.com

# ====================== 公网访问与 Webhook ======================
# 生产环境必填：服务器公网域名（用于 Ozon Webhook 回调和 HTTPS）
PUBLIC_DOMAIN=CHANGE_ME_YOUR_DOMAIN_COM
# Ozon Webhook 来源 IP 白名单（逗号分隔，可选）
# OZON_WEBHOOK_IPS=185.73.193.0/24,91.206.14.0/24

# ====================== Ops Agent 运维机器人（飞书）======================
# FEISHU_APP_ID=CHANGE_ME_FEISHU_APP_ID
# FEISHU_APP_SECRET=CHANGE_ME_FEISHU_APP_SECRET
# OPS_AGENT_CHAT_ID=CHANGE_ME_FEISHU_CHAT_ID

# ====================== Promo Agent 推广机器人（飞书）======================
# 复用上方 Ops Agent 的 FEISHU_APP_ID / FEISHU_APP_SECRET（同一飞书应用）
# 需要单独配置 Promo Agent 的 Chat ID
PROMO_AGENT_CHAT_ID=CHANGE_ME_PROMO_CHAT_ID
# 以下密钥需在对应段配置：
#   FEISHU_APP_ID / FEISHU_APP_SECRET — 飞书应用凭证
#   DEEPSEEK_API_KEY — 文案生成 + AI 诊断
#   GLM_API_KEY      — 主图质量分析
#   API_KEY          — 与 api-services 通信认证

# ---- 智能定价 ----
# 自动调价开关（true=自动执行无需确认，false=仅建议需手动确认）
# 建议先设为 false，观察决策引擎评分是否合理后再开启
PROMO_AUTO_PRICING=false
# 最低利润率（低于此比例的调价需额外人工确认）
PROMO_MIN_PROFIT_RATE=0.10

# ---- 竞品数据源 ----
# MPStats API（俄罗斯电商数据分析平台，优先使用）
# MPSTATS_API_KEY=
# MPSTATS_BASE_URL=https://mpstats.io/api

# ---- 自主推广决策 ----
PROMO_AUTO_DECISION=true              # 启用自主决策引擎
PROMO_MAX_DAILY_SPEND=500             # 每日推广预算上限 (₽)
PROMO_DECISION_INTERVAL_HOURS=4       # 决策周期（小时）
PROMO_MAX_DAILY_ACTIONS=10            # 每日自动操作上限
PROMO_SCORE_THRESHOLD=40              # 推广评分阈值（低于此值跳过）
# PROMO_AB_TEST=false                   # 启用A/B测试
# PROMO_AB_CONTROL_RATIO=30             # 对照组比例(%)

# ====================== 异地备份配置（可选）======================
# RCLONE_REMOTE=s3:CHANGE_ME_BUCKET_NAME
# BACKUP_DIR=./data/backups
# BACKUP_RETENTION_DAYS=7
# BACKUP_INTERVAL_HOURS=6

# ====================== RAG 向量知识库 ======================
EMBEDDING_PROVIDER=zhipu
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSIONS=2048
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_TIMEOUT_MS=30000
EMBEDDING_BATCH_SIZE=16
RAG_INDEX_INTERVAL_MINUTES=60
RAG_SIMILARITY_THRESHOLD=0.7
