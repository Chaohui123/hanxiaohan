# ====================== GLM 智谱视觉模型（示例占位符）
GLM_API_KEY=YOUR_GLM_API_KEY_HERE
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_VISION_MODEL=glm-4.6v-flash

# ====================== DeepSeek 文本大模型（示例占位符）
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 常规上架低成本主力模型
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
# 复杂比价深度推理旗舰模型（仅少量场景启用）
DEEPSEEK_PRO_MODEL=deepseek-v4-pro

# ====================== Ozon 店铺API密钥配置（示例占位符）
OZON_API_KEYS=YOUR_OZON_API_KEYS_COMMA_SEPARATED
OZON_CLIENT_IDS=YOUR_OZON_CLIENT_IDS_COMMA_SEPARATED
OZON_API_BASE=https://api.ozon.ru/v3

# n8n
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_N8N_PASSWORD
N8N_ENCRYPTION_KEY=change_me_to_random_32_chars

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info


# ====================== 应用服务基础配置 ======================
# API 认证密钥（不设置则不启用鉴权，开发模式跳过鉴权）
API_KEY=CHANGE_ME_TO_RANDOM_32_CHARS
API_SERVICE_PORT=3000
# SQLite 本地数据库文件路径
SQLITE_DB_PATH=./data/onzo.db
# 模型并发令牌桶上限
MAX_AI_CONCURRENCY=10
# LLM 单日 Token 上限（0=不限制）
LLM_DAILY_TOKEN_LIMIT=500000
# 环境模式（dev=mock外部接口，production=真实调用）
ENV=production

# ====================== 通知渠道（可选） ======================
# 企业微信机器人 Webhook（留空不启用）
NOTIFY_WECHAT_WEBHOOK=
# Telegram Bot 通知（留空不启用）
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=

# ====================== Playwright 爬虫配置 ======================
SCRAPER_MAX_BROWSER_POOL=3
# 1688 反爬安全下限 3000ms，低于此值可能触发验证码拉黑
SCRAPER_REQUEST_DELAY_MIN=3000
SCRAPER_REQUEST_DELAY_MAX=5000

# ====================== 开发模式配置 ======================
# ENV=dev 启用开发模式（跳过鉴权），需同时设置 ENABLE_MOCK=true 才会返回假数据
# 生产环境确保 ENV=production 且 ENABLE_MOCK 未设置或为 false
# ENABLE_MOCK=true

# ====================== 订单同步 ======================
ORDER_SYNC_PAGE_SIZE=50
