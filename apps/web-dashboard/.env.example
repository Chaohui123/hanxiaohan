# ====================== Web Dashboard 环境变量 ======================
# 复制此文件为 .env 并填入真实值

# API 认证密钥（与后端 API_KEY 一致，生产环境必填）
VITE_API_KEY=CHANGE_ME_API_KEY

# API 后端地址（开发时留空使用 Vite proxy，生产构建时设为实际 URL）
# 开发环境: 留空（Vite proxy 自动转发 /api → localhost:3000）
# 生产环境: VITE_API_BASE=https://huashangshangmao.top
VITE_API_BASE=
