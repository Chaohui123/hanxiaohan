# ============================================================
# ONZO Caddy Reverse Proxy — Automatic HTTPS via Let's Encrypt
# Domain: set CADDY_DOMAIN in .env.production
# ============================================================

{$CADDY_DOMAIN:localhost} {
	# ---- Feishu Bot Callback (receives messages & button clicks) ----
	handle /feishu/* {
		reverse_proxy ops-agent:8181 {
			header_up X-Forwarded-For {remote_host}
		}
	}

	# ---- Ozon Webhook Receiver (must be public, no auth) ----
	# Ozon pushes order status changes to this endpoint.
	# Registered via: npx tsx scripts/setup-webhook.ts
	handle /api/webhook/ozon {
		reverse_proxy api-services:3000 {
			# Forward original client IP for IP whitelist validation
			header_up X-Forwarded-For {remote_host}
			header_up X-Real-IP {remote_host}
		}
	}

	# ---- API Endpoints ----
	handle /api/* {
		reverse_proxy api-services:3000 {
			header_up X-Forwarded-For {remote_host}
		}
	}

	# ---- Health Check (no auth required) ----
	handle /health {
		reverse_proxy api-services:3000
	}

	# ---- Metrics Endpoint ----
	handle /metrics {
		reverse_proxy api-services:3000
	}

	# ---- Web Dashboard (React SPA) ----
	# Static assets (JS/CSS/images) have content-hash filenames → immutable cache
	handle /assets/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy web-dashboard:80
	}
	# HTML entry point + all other SPA routes → no-cache
	handle {
		header Cache-Control "no-cache"
		reverse_proxy web-dashboard:80
	}

	# ---- Security Headers ----
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Disable FLoC / Topics API
		Permissions-Policy "interest-cohort=()"
	}

	# ---- Access Log (JSON format, rotated) ----
	log {
		output file /data/caddy/access.log {
			roll_size 10mb
			roll_keep 10
		}
		format json
	}
}
