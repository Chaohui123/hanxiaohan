# ============================================================
# ONZO Caddy Reverse Proxy — HTTPS + SPA + CORS + Monitor
# ============================================================

{$CADDY_DOMAIN:localhost} {
	# ---- CORS: allow third-party health checks ----
	@cors_preflight method OPTIONS
	handle @cors_preflight {
		header Access-Control-Allow-Origin "*"
		header Access-Control-Allow-Methods "GET, POST, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, X-API-Key, Authorization"
		respond 204
	}

	# ---- Root + Health (public, no auth, returns 200 to all) ----
	handle /health {
		reverse_proxy api-services:3000 {
			header_up X-Forwarded-For {remote_host}
			transport http { dial_timeout 5s }
		}
	}

	# ---- API Endpoints ----
	handle /api/* {
		reverse_proxy api-services:3000 {
			header_up X-Forwarded-For {remote_host}
			transport http {
				dial_timeout 10s
				response_header_timeout 120s
			}
		}
	}

	# ---- Feishu Bot Callback ----
	handle /feishu/* {
		reverse_proxy ops-agent:8181 {
			header_up X-Forwarded-For {remote_host}
			transport http { dial_timeout 5s }
		}
	}

	# ---- Ozon Webhook ----
	handle /api/webhook/ozon {
		reverse_proxy api-services:3000 {
			header_up X-Forwarded-For {remote_host}
			header_up X-Real-IP {remote_host}
			transport http { dial_timeout 10s }
		}
	}

	# ---- Static Assets (immutable, content-hash filenames) ----
	handle /assets/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy web-dashboard:80
	}

	# ---- Web Dashboard SPA (all other routes) ----
	handle {
		header Cache-Control "no-cache"
		reverse_proxy web-dashboard:80 {
			header_up X-Forwarded-For {remote_host}
			transport http { dial_timeout 5s }
		}
	}

	# ---- Security Headers ----
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}

	# ---- Access Log ----
	log {
		output file /data/caddy/access.log {
			roll_size 10mb
			roll_keep 10
		}
		format json
	}
}
